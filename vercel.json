{
  "buildCommand": "npm run build",
  "outputDirectory": "client/dist",
  "framework": null,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" },
    { "source": "/uploads/(.*)", "destination": "/api" },
    { "source": "/((?!api|uploads|assets|favicon|_next).*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/index.mjs": {
      "memory": 256,
      "maxDuration": 30
    }
  }
}
